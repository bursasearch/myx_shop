# .yamllint
extends: default

rules:
  truthy:
    allowed-values: ['true', 'false', 'on', 'off', 'yes', 'no']
    check-keys: false
  line-length:
    max: 120
    level: warning
  comments-indentation: disable
  empty-values: disable

overrides:
  - files: ".github/workflows/*.yml"
    rules:
      truthy:
        allowed-values: ['true', 'false', 'on', 'off', 'yes', 'no']
        check-keys: false
      line-length:
        max: 120
        level: warning
      comments-indentation: disable
      empty-values: disable
