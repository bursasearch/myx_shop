# Myx Shop Git Ignore

# Admin 文件夹 - 包含敏感数据/备份等
admin/

# 临时文件和备份文件
*.tmp
*.bak
*.backup
*~
*.swp
*.swo

# 日志文件
*.log
logs/

# 环境变量和敏感数据
.env
.env.local
.env.production
secrets/
config/private/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 文件
.vscode/
.idea/
*.swp
*.swo

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 缓存文件夹
.cache/
tmp/
temp/

# 大型数据文件（如果不需要版本控制）
*.csv
*.xlsx
*.xls
*.pdf

# 压缩包
*.zip
*.tar
*.gz

# 原始大文件（如果已有压缩版本）
*_original.*
*_uncompressed.*
*_large.*

# 开发工具生成的文件
dist/
build/
out/
*.min.js
*.min.css

# 本地测试文件
test_output/
local_test/
