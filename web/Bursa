#!/bin/bash
# 自動打開AI選股報告
echo "🚀 正在打開AI選股分析報告..."
echo "請稍候..."

# 嘗試用不同方式打開HTML文件
if command -v termux-open &> /dev/null; then
    termux-open "ai_analysis_preview.html"
    echo "✅ 已通過Termux打開報告"
elif command -v xdg-open &> /dev/null; then
    xdg-open "ai_analysis_preview.html"
    echo "✅ 已通過xdg-open打開報告"
else
    echo "🌐 請手動打開: file://$(pwd)/ai_analysis_preview.html"
    echo "💡 或在瀏覽器中輸入上述URL"
fi

# 顯示可用文件
echo ""
echo "📁 web目錄可用文件:"
ls -la *.html *.json 2>/dev/null | awk '{print $9, "(" $5 " bytes)"}'
