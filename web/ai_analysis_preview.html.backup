                <i class="fas fa-home"></i> 回到主頁
            </a>
            <a href="../bursa.html" class="action-btn">
                <i class="fas fa-chart-line"></i> 回到AI選股
            </a>
            <a href="retail-inv.html" class="action-btn secondary">
                <i class="fas fa-chart-bar"></i> 使用回測工具
            </a>
            <a href="mobile_recording.html" class="action-btn secondary">
                <i class="fas fa-mobile-alt"></i> 手機錄屏版本
            </a>
            <button onclick="window.print()" class="action-btn secondary">
                <i class="fas fa-print"></i> 打印報告
            </button>
        </div>
        
        <!-- 页脚 -->
        <div class="footer">
            <p><i class="fas fa-exclamation-triangle" style="color: #ffc107;"></i> <strong>免責聲明:</strong> 此分析報告僅供參考，不構成投資建議。投資有風險，請謹慎決策。</p>
            <p style="margin-top: 15px;">
                <i class="fas fa-info-circle"></i> 更新頻率: Daily | 
                <i class="fas fa-code"></i> 版本: AI Stock Picker v1.0 | 
                <i class="fas fa-calendar-alt"></i> © 2025 AI選股分析系統
            </p>
        </div>
    </div>
    
    <script>
        // 添加一些简单的交互效果
        document.addEventListener('DOMContentLoaded', function() {
            // 为表格行添加点击效果
            const tableRows = document.querySelectorAll('tbody tr');
            tableRows.forEach(row => {
                row.addEventListener('click', function() {
                    const code = this.cells[1].textContent.trim();
                    alert('選中股票: ' + code + '\n詳細分析請查看AI選股主頁。');
                });
            });
            
            // 更新当前时间
            function updateCurrentTime() {
                const now = new Date();
                const timeStr = now.toLocaleString('zh-TW', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: false
                });
                document.querySelector('.header-info .info-item:first-child').innerHTML = 
                    `<i class="fas fa-calendar-alt"></i> 生成時間: ${timeStr}`;
            }
            
            // 每秒更新一次时间
            setInterval(updateCurrentTime, 1000);
            
            // 添加打印样式
            const style = document.createElement('style');
            style.textContent = `
                @media print {
                    .nav-bar, .quick-actions, .action-btn { display: none !important; }
                    body { background: white !important; }
                    .section { box-shadow: none !important; border: 1px solid #ddd; }
                }
            `;
            document.head.appendChild(style);
        });
    </script>
</body>
</html>
EOF

