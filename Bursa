  <script>
    // 影片管理器
    class VideoManager {
      constructor() {
        this.videos = [];
        this.currentFilter = 'all';
        this.init();
      }

      init() {
        this.loadVideos();
        this.setupEventListeners();
        
        // 添加頁面加載動畫效果
        this.addPageAnimations();
      }

      setupEventListeners() {
        // 篩選器事件
        document.querySelectorAll('.filter-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            this.handleFilter(e.target.dataset.filter, e.target);
          });
        });

        // 模態框關閉事件
        document.addEventListener('click', (e) => {
          if (e.target.classList.contains('close-modal') || 
              e.target.classList.contains('video-modal')) {
            this.closeModal();
          }
        });
      }

      handleFilter(filter, target) {
        // 更新活動按鈕
        document.querySelectorAll('.filter-btn').forEach(btn => {
          btn.classList.remove('active');
        });
        target.classList.add('active');
        
        this.currentFilter = filter;
        this.renderVideos();
      }

      loadVideos() {
        // 這裡可以替換為從您的 JSON 檔案或 API 載入
        this.videos = [
          {
            id: 'AxlIA-OivOs',
            title: '【Ai選股】2025年11月6日成績揭曉',
            category: 'analysis',
            date: '2025-11-06',
            description: 'AI選股最新成績分析與市場洞察'
          },
          {
            id: 'dQw4w9WgXcQ',
            title: 'AI選股基礎教學 - 新手入門指南',
            category: 'tutorial', 
            date: '2025-11-05',
            description: '學習AI選股的基本概念和操作技巧'
          },
          {
            id: '9bZkp7q19f0',
            title: '技術分析進階策略',
            category: 'strategy',
            date: '2025-11-04',
            description: '深入了解技術分析的高級應用方法'
          },
          {
            id: 'kJQP7kiw5Fk',
            title: '市場趨勢與風險管理',
            category: 'analysis',
            date: '2025-11-03',
            description: '分析當前市場趨勢並學習風險控制技巧'
          },
          {
            id: '3JZ_D3ELwOQ',
            title: '價值投資與AI結合',
            category: 'strategy',
            date: '2025-11-02',
            description: '如何將傳統價值投資與AI分析相結合'
          },
          {
            id: 'CevxZvSJLk8',
            title: '投資心理學與情緒控制',
            category: 'tutorial',
            date: '2025-11-01',
            description: '掌握投資心理學，避免情緒化決策'
          }
        ];

        this.renderVideos();
      }

      renderVideos() {
        const grid = document.getElementById('videoGrid');
        const filteredVideos = this.currentFilter === 'all' 
          ? this.videos 
          : this.videos.filter(video => video.category === this.currentFilter);

        if (filteredVideos.length === 0) {
          grid.innerHTML = '<div class="loading-spinner">暫無相關影片</div>';
          return;
        }

        grid.innerHTML = filteredVideos.map(video => `
          <div class="video-item" onclick="videoManager.openVideo('${video.id}')">
            <div class="video-thumbnail">
              <img src="https://img.youtube.com/vi/${video.id}/hqdefault.jpg" 
                   alt="${video.title}"
                   onerror="this.src='https://via.placeholder.com/320x180/667eea/white?text=影片預覽'">
              <div class="play-overlay">
                <i class="fas fa-play play-icon"></i>
              </div>
            </div>
            <div class="video-info">
              <div class="video-title">${video.title}</div>
              <div class="video-meta">
                <span>${video.date}</span>
                <span class="video-category">${this.getCategoryName(video.category)}</span>
              </div>
            </div>
          </div>
        `).join('');
      }

      getCategoryName(category) {
        const categories = {
          'tutorial': '教學指南',
          'analysis': '市場分析', 
          'strategy': '投資策略'
        };
        return categories[category] || category;
      }

      openVideo(videoId) {
        const video = this.videos.find(v => v.id === videoId);
        if (!video) return;

        const modal = document.getElementById('videoModal');
        modal.innerHTML = `
          <div class="modal-content">
            <span class="close-modal">&times;</span>
            <div class="modal-video-container">
              <iframe src="https://www.youtube.com/embed/${videoId}" 
                      frameborder="0" 
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                      allowfullscreen>
              </iframe>
            </div>
            <div class="modal-video-info">
              <h3>${video.title}</h3>
              <p>${video.description}</p>
              <div class="video-meta">
                <span>${video.date}</span>
                <span class="video-category">${this.getCategoryName(video.category)}</span>
              </div>
            </div>
          </div>
        `;

        modal.style.display = 'block';
        document.body.style.overflow = 'hidden';
      }

      closeModal() {
        const modal = document.getElementById('videoModal');
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
        
        // 清除影片嵌入以避免後台播放
        const iframe = modal.querySelector('iframe');
        if (iframe) {
          iframe.src = '';
        }
      }

      addPageAnimations() {
        const elements = document.querySelectorAll('.stock-card, .video-section, .latest-video');
        elements.forEach((element, index) => {
          element.style.opacity = '0';
          element.style.transform = 'translateY(20px)';
          
          setTimeout(() => {
            element.style.transition = 'all 0.6s ease';
            element.style.opacity = '1';
            element.style.transform = 'translateY(0)';
          }, index * 200);
        });
      }
    }

    // 自動更新器
    class AutoUpdater {
      constructor() {
        this.lastUpdate = localStorage.getItem('lastVideoUpdate');
        this.updateInterval = 30 * 60 * 1000; // 30分鐘
        this.init();
      }

      init() {
        this.checkForUpdates();
        setInterval(() => this.checkForUpdates(), this.updateInterval);
      }

      async checkForUpdates() {
        try {
          // 模擬API調用 - 實際使用時替換為真實API
          const newVideos = await this.fetchLatestVideos();
          
          if (this.hasNewVideos(newVideos)) {
            this.showUpdateNotification(newVideos);
            this.updateLastUpdate(newVideos);
          }
        } catch (error) {
          console.log('檢查更新失敗:', error);
        }
      }

      async fetchLatestVideos() {
        // 模擬API響應 - 實際使用時替換為真實API調用
        return new Promise(resolve => {
          setTimeout(() => {
            resolve([
              {
                id: 'NEW_VIDEO_ID',
                title: '【最新】AI選股今日推薦',
                category: 'analysis',
                date: new Date().toISOString().split('T')[0]
              }
            ]);
          }, 1000);
        });
      }

      hasNewVideos(newVideos) {
        return newVideos.length > 0 && 
               newVideos[0].date !== this.lastUpdate;
      }

      showUpdateNotification(videos) {
        const notification = document.createElement('div');
        notification.className = 'update-notification';
        
        notification.innerHTML = `
          <strong>有新影片更新!</strong>
          <div style="font-size:0.9rem; margin-top:0.5rem;">
            ${videos[0].title}
          </div>
          <div style="font-size:0.8rem; margin-top:0.3rem; opacity:0.9;">
            點擊查看詳情
          </div>
        `;
        
        notification.onclick = () => {
          // 這裡可以實現跳轉到新影片的功能
          videoManager.openVideo(videos[0].id);
          notification.remove();
        };

        document.body.appendChild(notification);
        
        setTimeout(() => {
          if (notification.parentNode) {
            notification.remove();
          }
        }, 5000);
      }

      updateLastUpdate(videos) {
        if (videos.length > 0) {
          localStorage.setItem('lastVideoUpdate', videos[0].date);
        }
      }
    }

    // 初始化
    document.addEventListener("DOMContentLoaded", function() {
      console.log("AI選股分析頁面已載入完成");
      
      // 初始化影片管理器
      window.videoManager = new VideoManager();
      
      // 初始化自動更新
      window.autoUpdater = new AutoUpdater();

      // 瀏覽器兼容性檢查
      if (typeof(Storage) !== "undefined") {
          console.log("本地存儲支持已啟用");
      } else {
          console.warn("瀏覽器不支持本地存儲，部分功能可能無法使用");
      }
    });
  </script>

  <!-- 股票更新功能 -->
  <script src="js/update_stocks.js"></script>
  <script src="js/auto_update_stocks.js"></script>

</body>
