        'status': 'running',
        'server_time': datetime.now().isoformat(),
        'working_directory': os.getcwd(),
        'files': {
            'shopee_data': os.path.exists('js/shopee_lists.json'),
            'ai_stocks': os.path.exists('ai_stocks.json'),
            'images_directory': os.path.exists('images/products/shopee'),
            'admin_directory': os.path.exists('admin')
        }
    })

@app.route('/health')
def health():
    """健康检查"""
    return jsonify({
        'status': 'healthy', 
        'timestamp': datetime.now().isoformat(),
        'version': '1.0.0',
        'services': {
            'shopee': 'active',
            'stocks': 'active',
            'images': 'active',
            'admin': 'active'
        }
    })

# ==================== 错误处理 ====================
@app.errorhandler(404)
def not_found(error):
    return jsonify({'error': '接口未找到', 'path': request.path}), 404

@app.errorhandler(500)
def internal_error(error):
    return jsonify({'error': '服务器内部错误'}), 500

if __name__ == '__main__':
    print("=" * 50)
    print("Myx Shop 服务器启动中...")
    print(f"工作目录: {os.getcwd()}")
    print("可用服务:")
    print("  - 主页面: http://127.0.0.1:5000/")
    print("  - Shopee产品: http://127.0.0.1:5000/shopee.html")
    print("  - 管理后台: http://127.0.0.1:5000/admin/shopee_dashboard.html")
    print("  - 产品API: http://127.0.0.1:5000/api/shopee/products")
    print("  - 系统信息: http://127.0.0.1:5000/api/system/info")
    print("  - 健康检查: http://127.0.0.1:5000/health")
    print("=" * 50)
    
    app.run(debug=True, host='127.0.0.1', port=5000)