from flask import Flask, jsonify, request, send_from_directory
from flask_cors import CORS
import subprocess
import os
import json
from datetime import datetime, timedelta
import shutil
import requests
import csv
import io

app = Flask(__name__)
CORS(app, resources={r"/*": {"origins": "*"}})

# ==================== 静态文件服务配置 ====================
@app.route('/')
def serve_index():
    """服务主页面"""
    try:
        return send_from_directory('.', 'index.html')
    except FileNotFoundError:
        return "主页未找到", 404

@app.route('/<path:filename>')
def serve_static_files(filename):
    """服务所有静态文件"""
    try:
        return send_from_directory('.', filename)
    except FileNotFoundError:
        return f"文件未找到: {filename}", 404

# 专门为 admin 文件夹提供服务
@app.route('/admin/<path:filename>')
def serve_admin_files(filename):
    """服务 admin 文件夹中的文件"""
    try:
        return send_from_directory('admin', filename)
    except FileNotFoundError:
        return f"管理文件未找到: {filename}", 404

@app.route('/images/<path:filename>')
def serve_images(filename):
    """服务图片文件"""
    try:
        return send_from_directory('images', filename)
    except FileNotFoundError:
        return f"图片未找到: {filename}", 404

@app.route('/js/<path:filename>')
def serve_js(filename):
    """服务JS文件"""
    try:
        return send_from_directory('js', filename)
    except FileNotFoundError:
        return f"JS文件未找到: {filename}", 404

# 专门为Shopee产品图片提供服务
@app.route('/images/products/shopee/<path:filename>')
def serve_shopee_images(filename):
    """服务Shopee产品图片"""
    try:
